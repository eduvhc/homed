# Secrets — committed encriptados (sops in-place, auto-detect por conteúdo).
# Convenção: secrets/*.env contém SOPS payload no git; `task decrypt` decifra
# in-place para o stack local (e o doco-cd faz o mesmo num clone fresh).
# Apenas o template do h-doco-cd e qualquer plaintext acidental fora de
# secrets/ ficam ignorados.
secrets/.env
**/.env.local
**/.env.tmp

# Compose local overrides
compose/compose.override.yaml

# Tofu
tofu/.terraform/
tofu/.terraform.lock.hcl
tofu/*.tfstate
tofu/*.tfstate.backup
tofu/crash.log

# Estado runtime das apps (vive em backup Restic, NÃO no git).
# Configs declarativos ficam versionados — listamos só o state.
compose/stacks/arr/h-qbittorrent/config/
compose/stacks/arr/h-lidarr/config/
compose/stacks/arr/h-prowlarr/config/
compose/stacks/arr/h-sonarr/config/
compose/stacks/arr/h-radarr/config/
compose/stacks/media/navidrome/config/
compose/stacks/network/h-adguard/config/work/
compose/stacks/ops/h-yt-dlp/state/
compose/stacks/ops/h-yt-dlp/downloads/

# Authelia runtime: OIDC private key (gerada on first run), session db, notification queue
compose/stacks/infra/h-auth/config/oidc-issuer.pem
compose/stacks/infra/h-auth/config/db.sqlite3
compose/stacks/infra/h-auth/config/notification.txt

# Homepage runtime logs
compose/stacks/ops/h-dashboard/config/logs/

# Media e downloads partilhados (vivem em backup Restic, não no git)
data/

# Sistema
.DS_Store
*.swp
